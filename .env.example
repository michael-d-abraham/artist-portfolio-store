MONGO_STRING=
DB_NAME=

SESSION_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Stripe Checkout — use SECRET key (sk_test_...), NOT publishable (pk_...)
# Dashboard: https://dashboard.stripe.com/test/apikeys → "Secret key"
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Must match the Vite URL in your terminal (e.g. 5173 or 5174 if 5173 is in use)
CLIENT_URL=http://localhost:5173
# Optional — must still include {CHECKOUT_SESSION_ID} if set:
# STRIPE_SUCCESS_URL=http://localhost:5173/order-success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=http://localhost:5173/checkout/cancel
