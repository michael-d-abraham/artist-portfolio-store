# ─── Server ───────────────────────────────────────────────────────────────────

# HTTP port Express listens on (default: 3000)
PORT=3000

# Set to "production" by `npm start`. Controls secure cookies, trust-proxy,
# and static SPA serving from frontend/dist. Leave unset in development.
# NODE_ENV=production


# ─── Database ─────────────────────────────────────────────────────────────────

# MongoDB connection URI, e.g. mongodb://localhost:27017 or a MongoDB Atlas URI
MONGO_STRING=mongodb://localhost:27017

# Database name, e.g. artist_portfolio
DB_NAME=artist_portfolio


# ─── Session ──────────────────────────────────────────────────────────────────

# Signs the session cookie — use a long random string, never expose it
SESSION_SECRET=change-me-to-a-long-random-string

# Sessions (admin login + cart) are stored in the MongoDB "sessions" collection.
# On Render/Heroku set NODE_ENV=production — trust proxy is enabled automatically.


# ─── Admin Accounts ───────────────────────────────────────────────────────────

# Primary admin credentials (upserted into MongoDB on server start)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional secondary / master admin account
# ADMIN_MASTER_USERNAME=master
# ADMIN_MASTER_PASSWORD=change-me


# ─── Stripe ───────────────────────────────────────────────────────────────────

# Server-side secret key — use sk_test_... (test) or sk_live_... (production)
# Dashboard: https://dashboard.stripe.com/test/apikeys → "Secret key"
# Do NOT use the publishable key (pk_...) here.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from `stripe listen` output in dev, or Stripe dashboard in prod
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL of the frontend. Used to build Stripe success_url and cancel_url.
# Must match the Vite port shown in your terminal (5173 is the default, 5174 if 5173 is in use).
CLIENT_URL=http://localhost:5173

# Deprecated legacy alias for CLIENT_URL — CLIENT_URL takes precedence.
# Only set this if migrating from an older deployment that used FRONTEND_URL.
# FRONTEND_URL=http://localhost:5173

# Optional overrides for Stripe redirect URLs.
# STRIPE_SUCCESS_URL must include the literal {CHECKOUT_SESSION_ID} placeholder.
# STRIPE_SUCCESS_URL=http://localhost:5173/order-success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=http://localhost:5173/checkout/cancel


# ─── Cloudflare R2 (image uploads) ───────────────────────────────────────────

# Create an API token and bucket in the Cloudflare dashboard.
# Enable public read access on products/* (or use a custom domain).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# S3-compatible API endpoint for your account
# e.g. https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Public base URL for stored objects — no trailing slash
# e.g. https://assets.yourdomain.com  or  https://pub-<hash>.r2.dev
R2_PUBLIC_URL=


# ─── Email (Resend) ───────────────────────────────────────────────────────────

# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified sender address in Resend (required in production).
# Falls back to onboarding@resend.dev in Resend sandbox — only works for test sends.
# e.g. PermSite <noreply@yourdomain.com>
RESEND_FROM_EMAIL=

# Recipient for order notifications and contact form submissions.
# If unset, falls back to the contact email set in Admin → Links.
NOTIFICATION_EMAIL=


# ─── AI / Ollama (admin Instagram copy generator) ────────────────────────────

# URL of the Ollama server.
# Default if unset: http://golem:11434 (private dev machine — always set this explicitly).
OLLAMA_HOST=http://localhost:11434

# Ollama model name to use for generation.
# Default if unset: gpt-oss:20b — replace with a model you have pulled locally.
OLLAMA_MODEL=llama3.2
